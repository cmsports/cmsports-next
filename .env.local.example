NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...tu-service-role-key

# Opcionales
OPENAI_API_KEY=
RESEND_API_KEY=
VERCEL_MONITOR_TOKEN=

# Sentry (error tracking). Sin el DSN, Sentry queda desactivado y la app funciona igual.
# El DSN sale de: Sentry → Settings → Projects → [tu proyecto] → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
# Solo para subir source maps en el build (opcional). Se generan en Sentry → Settings.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
